# ================================
# 🔧 IMPACT ID BACKEND CONFIGURATION
# ================================
# Environment Configuration for Development
# Copy this to .env and customize for your setup
# NEVER commit .env files to version control!

# ------------------------------
# CORE APPLICATION SETTINGS
# ------------------------------
# Environment: development, staging, production, testing
ENVIRONMENT=development
# Debug mode for detailed error messages
DEBUG=true
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ------------------------------
# SECURITY CONFIGURATION
# ------------------------------
# Secret key for JWT signing (MUST be at least 32 characters)
SECRET_KEY=your-super-secret-development-key-change-in-production-32-chars-minimum
# Session timeout in seconds (24 hours)
SESSION_TIMEOUT=86400
# JWT token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh token expiration in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------
# DATABASE CONFIGURATION
# ------------------------------
# SQLite with async driver for development
DATABASE_URL=sqlite+aiosqlite:///./impact.db
# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_QUERY_TIMEOUT=30
DB_ECHO=false
DB_HEALTH_CHECK_INTERVAL=300

# ------------------------------
# CORS & SECURITY
# ------------------------------
# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500
# Allowed hosts for production
ALLOWED_HOSTS=localhost,127.0.0.1,*

# ------------------------------
# APPLICATION URLS
# ------------------------------
# Base URL for the API
BASE_URL=http://localhost:8000
# Frontend URL for generating links
FRONTEND_URL=http://localhost:5173

# ------------------------------
# FEATURE FLAGS
# ------------------------------
# Enable application monitoring
ENABLE_MONITORING=true
# Enable email functionality
ENABLE_EMAIL=false
# Enable background tasks
ENABLE_BACKGROUND_TASKS=true

# ------------------------------
# EMAIL CONFIGURATION (SMTP)
# ------------------------------
# SMTP server settings (leave empty to disable email)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=noreply@impactid.com
EMAIL_FROM_NAME=Impact ID

# ------------------------------
# ADMIN USER SEEDING
# ------------------------------
# Default admin user credentials (change in production!)
ADMIN_EMAIL=admin@impactid.com
ADMIN_PASSWORD=admin123
ADMIN_USERNAME=admin

# ------------------------------
# IMPACT HARVESTER CONFIGURATION
# ------------------------------
# RSS feed URLs for content harvesting (comma-separated)
RSS_FEEDS=https://news.un.org/feed/subscribe/en/news/topic/human-rights/feed/rss.xml,https://www.theguardian.com/environment/rss
# Keywords for content relevance filtering (comma-separated)
RELEVANCE_KEYWORDS=sustainability,humanitarian,climate action,non-profit,charity,volunteer,social impact,environmental justice,conservation,empowerment

# ------------------------------
# RATE LIMITING
# ------------------------------
# Rate limit: requests per period
RATE_LIMIT_CALLS=100
# Rate limit period in seconds
RATE_LIMIT_PERIOD=60

# ------------------------------
# DEVELOPMENT SETTINGS
# ------------------------------
# Enable development debug endpoints
DEV_MODE=true
# Auto-reload on code changes
AUTO_RELOAD=true

# Development environment variables
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_APP_TITLE=Impact ID
VITE_APP_DESCRIPTION=Gamified Impact Platform
VITE_ENABLE_DEVTOOLS=true
VITE_USE_POLLING=false
