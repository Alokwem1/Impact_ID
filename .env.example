# Impact ID Environment Configuration Example
# Copy to .env and adjust values for your deployment

# =====================
# Core Application
# =====================
ENVIRONMENT=production
APP_VERSION=2.0.0
SERVICE_NAME=impact-id-backend
DEBUG=false
LOG_LEVEL=INFO
JSON_LOGS=true
THIRD_PARTY_LOG_LEVEL=WARNING

# =====================
# Security / Auth
# =====================
SECRET_KEY=change_me_please_generate_a_long_random_value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# =====================
# Database
# =====================
# For Postgres: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://impact_user:change_me@postgres:5432/impact_id_prod
# For local dev alternative (SQLite): sqlite+aiosqlite:///./impact.db

# =====================
# CORS / Frontend
# =====================
ALLOWED_ORIGINS=https://impactid.xyz,https://app.impactid.xyz

# =====================
# Email (if implemented)
# =====================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_FROM_ADDRESS=no-reply@impactid.xyz

# =====================
# Observability
# =====================
ENABLE_METRICS=true
ENABLE_REQUEST_LOGGING=true

# =====================
# Rate Limiting
# =====================
RATE_LIMIT_DEFAULT=100/minute

# =====================
# Feature Flags
# =====================
ENABLE_WEAVING=true
ENABLE_BADGES=true
ENABLE_NOTIFICATIONS=true
