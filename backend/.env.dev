# Development environment overrides
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-super-secret-change-me-please-32chars-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
RUN_DB_MIGRATIONS=0
ALLOW_LEGACY_TABLE_CREATION=1
ENABLE_TOKEN_ROTATION=false
ENABLE_TOKEN_BLACKLISTING=false
REQUIRE_SECURE_TOKENS=false
# Comment out REDIS_URL to suppress connection attempts or point to real instance
# REDIS_URL=redis://localhost:6379
