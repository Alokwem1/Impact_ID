# Impact ID Backend Environment Example
# Copy this file to .env and adjust values for your environment.

# --- Core App ---
APP_ENV=production
APP_NAME=ImpactID
BASE_URL=http://localhost:8000

# --- Security / Auth ---
SECRET_KEY=change_me_to_random_64_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=43200
ALGORITHM=HS256
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./impact.db
# For Postgres (recommended prod):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/impact

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email (adjust / integrate with your provider) ---
EMAIL_SENDER=noreply@impactid.xyz
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_TLS=True

# --- Rate Limiting / Throttling ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=300

# --- Observability (optional) ---
LOG_LEVEL=INFO

# --- WebSocket ---
WEBSOCKET_MAX_CONNECTIONS=1000

# --- Feature Flags ---
ENABLE_EMAIL_VERIFICATION=true
ENABLE_BADGES=true
ENABLE_WEAVING=true
ENABLE_LEADERBOARD=true
